# ---------------------------------------------------------------------------
# Prevora environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# ---------------------------------------------------------------------------

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database (Project Settings -> Database -> Connection string)
# Pooled connection (pgbouncer) for the app; direct for migrations.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI provider (pluggable). provider = openai | anthropic | mock
AI_PROVIDER="mock"
AI_MODEL="gpt-4o-mini"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@prevora.app"

# FedaPay payments (https://fedapay.com -> Dashboard)
# Secret key: sk_sandbox_... (test) or sk_live_... (production). Empty => mock mode.
FEDAPAY_SECRET_KEY=""
# Webhook endpoint secret (Dashboard -> Webhooks -> reveal). Used to verify X-FEDAPAY-SIGNATURE.
FEDAPAY_WEBHOOK_SECRET=""
