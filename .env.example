# ---------------------------------------------------------------------------
# Prevora environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# ---------------------------------------------------------------------------

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database (Project Settings -> Database -> Connection string)
# Pooled connection (pgbouncer) for the app; direct for migrations.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI provider (pluggable). provider = openai | anthropic | mock
AI_PROVIDER="mock"
AI_MODEL="gpt-4o-mini"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@prevora.app"

# Bictorys payments (https://dashboard.bictorys.com -> Developpeurs)
# Sandbox: use the test secret key (contains "test"). Production: use the LIVE secret key.
BICTORYS_API_KEY=""
# Webhook "Clé secrète" from the dashboard webhook you register.
BICTORYS_WEBHOOK_SECRET=""
# Merchant country ISO code (CI = Côte d'Ivoire, SN = Sénégal, ...).
BICTORYS_COUNTRY="CI"
